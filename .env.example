# =============================================================================
# GPT Innovation OS — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# =============================================================================

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=sk-your-openai-key-here

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Notion ---
NOTION_API_KEY=secret_your-notion-integration-token
NOTION_DATABASE_ID=your-notion-database-id

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# --- Vercel ---
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3001
NEXT_PUBLIC_COMMAND_CENTER_URL=http://localhost:3002
NEXT_PUBLIC_AI_DASHBOARD_URL=http://localhost:3003

# --- Auth (NextAuth / Better Auth) ---
AUTH_SECRET=your-32-char-random-secret-here
AUTH_URL=http://localhost:3000

# --- MCP ---
MCP_SERVER_PORT=8080
MCP_AUTH_TOKEN=your-mcp-auth-token
